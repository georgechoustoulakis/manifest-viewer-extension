{
  "manifest_version": 3,
  "name": "HLS Manifest Viewer",
  "version": "1.0.0",
  "description": "View and navigate HLS .m3u8 manifests with syntax highlighting. Built for video engineers.",
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "HLS Manifest Viewer"
  },
  "permissions": [
    "storage",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
